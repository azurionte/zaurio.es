{
  "name": "payslip-desktop",
  "version": "5.0.6",
  "main": "main.js",
  "description": "Zaurio demo building tools",
  "author": "Zaurio",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:unsigned": "electron-builder -c.win.signAndEditExecutable=false"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "es.zaurio.payslip",
    "productName": "Demo Building Tools",
    "files": [
      "index.html",
      "demo-resources-v2.html",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "publish": {
      "provider": "generic",
      "url": "https://zaurio.es/payslip-updates/"
    },
    "nsis": {
      "perMachine": false,
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "DemoBuildingToolsSetup-${version}.${ext}"
    },
    "nsisWeb": {
      "perMachine": false,
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "DemoBuildingToolsWebSetup-${version}.${ext}"
    },
    "win": {
      "target": "nsis",
      "signAndEditExecutable": true
    }
  }
}
