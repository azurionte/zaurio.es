{
  "name": "payslip-desktop",
  "version": "5.0.41",
  "main": "main.js",
  "description": "Demo Building Tools desktop app for ADP demo document preparation",
  "author": "Maximiliano Robles",
  "companyName": "ADP",
  "copyright": "Copyright (c) 2026 ADP. Built by Maximiliano Robles.",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:unsigned": "electron-builder -c.win.signAndEditExecutable=false"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "es.zaurio.payslip",
    "productName": "Demo Building Tools",
    "files": [
      "index.html",
      "mini-apps/**/*",
      "assets/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "publish": {
      "provider": "generic",
      "url": "https://zaurio.es/payslip-updates/"
    },
    "releaseInfo": {
      "releaseNotes": "Moves Germany preview to an Australia-style owned sidebar and preview controller."
    },
    "nsis": {
      "perMachine": false,
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "DemoBuildingToolsSetup-${version}.${ext}"
    },
    "nsisWeb": {
      "perMachine": false,
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "artifactName": "DemoBuildingToolsWebSetup-${version}.${ext}"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/dbt-icon.ico",
      "legalTrademarks": "ADP",
      "signAndEditExecutable": true
    }
  }
}
