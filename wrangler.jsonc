{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zaurioes",
  "main": "_worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "binding": "ASSETS",
    "run_worker_first": true,
    "html_handling": "none"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
